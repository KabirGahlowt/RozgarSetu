# CORS is auto-allowed for http://<LAN-IP>:5173 in dev. Add more origins only if needed:
# CORS_ORIGINS=https://myapp.com

HOST=0.0.0.0
PORT=8000
MONGO_URI=
SECRET_KEY=

# Hosted API (Render): set NODE_ENV=production if cookies stay "Lax" in logs, or use FORCE_CROSS_SITE_COOKIES=true
# Vercel frontend: set VITE_API_BASE_URL=https://your-api.onrender.com (no trailing slash). Redeploy after changing.
# Custom domain on Vercel (not *.vercel.app): add exact origin to CORS_ORIGINS below, e.g. https://www.yoursite.com
