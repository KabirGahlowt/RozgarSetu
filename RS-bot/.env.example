# Backend API (Node/Mongo) — used by DataLoader to fetch workers at runtime.
# On Render, use your deployed backend URL, e.g. https://your-api.onrender.com/api/v1
BACKEND_API_URL=http://localhost:8000/api/v1

# Optional: train CHK-SVM during the Render build (set in dashboard). Requires BACKEND_API_URL reachable from build network or bundled CSV data.
# TRAIN_ON_BUILD=1

# Maps (optional; falls back to Nominatim)
GOOGLE_MAPS_API_KEY=

# Render injects PORT at runtime — local uvicorn can use 8001 via api/main.py default
# PORT=8001
